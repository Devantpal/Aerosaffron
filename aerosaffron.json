{
  "aerosaffron": {
    "sensors": {
      "temperature": 25,
      "humidity": 60,
      "light": 200,
      "waterLevel": 50
    },
    "controls": {
      "pump": 0,
      "light": 0,
      "fan": 0,
      "peltier": 0
    },
    "settings": {
      "tempSet": 23,
      "humSet": 65,
      "mistDuration": 30,
      "mistInterval": 15,
      "ledStart": "06:00",
      "ledEnd": "22:00"
    },
    "alerts": {
      "msg": "System Normal"
    },

    "automation": {
      "rule1": {
        "condition": "temperature > 24",
        "action": "peltier_on",
        "status": 1
      },
      "rule2": {
        "condition": "humidity < 50",
        "action": "pump_on",
        "status": 1
      },
      "rule3": {
        "condition": "waterLevel < 20",
        "action": "alert",
        "status": 1
      }
    }
  }
}